@model List<User>
@{
    ViewData["Title"] = "Users";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4>👥 Users</h4>
    <a asp-action="Create" class="btn btn-primary btn-sm">+ New User</a>
</div>

@if (TempData["Message"] != null)
{
    <div class="alert alert-success">@TempData["Message"]</div>
}

<div class="card">
    <table class="table table-hover mb-0">
        <thead class="table-dark">
            <tr><th>ID</th><th>Name</th><th>Email</th><th>Actions</th></tr>
        </thead>
        <tbody>
            @foreach (var user in Model)
            {
                <tr>
                    <td><code>@user.Id</code></td>
                    <td>@user.Name</td>
                    <td>@user.Email</td>
                    <td>
                        <a asp-action="Orders" asp-route-userId="@user.Id" class="btn btn-sm btn-outline-primary">Orders</a>
                        <a asp-action="Delete" asp-route-id="@user.Id" class="btn btn-sm btn-outline-danger"
                           onclick="return confirm('Delete this user?')">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
