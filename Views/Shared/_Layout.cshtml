<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Agent App</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        body { background: #f8f9fa; }
        .agent-badge { background: #6f42c1; color: white; font-size: 11px; padding: 2px 7px; border-radius: 10px; }
        .chat-box { background: white; border-radius: 12px; padding: 20px; min-height: 200px; border: 1px solid #dee2e6; }
        .response-box { background: #f0f4ff; border-left: 4px solid #6f42c1; padding: 15px; border-radius: 6px; white-space: pre-wrap; }
        .loading { display: none; }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4">
        <div class="container">
            <a class="navbar-brand" href="/">🤖 Agent App <span class="agent-badge">llama3.1</span></a>
            <div class="navbar-nav ms-auto">
                <a class="nav-link" asp-controller="Home" asp-action="Index">User/Order Agent</a>
                <a class="nav-link" asp-controller="Chat" asp-action="Index">Chat</a>
                <a class="nav-link" asp-controller="Users" asp-action="Index">Users</a>
                <a class="nav-link" asp-controller="Orders" asp-action="Index">Orders</a>
                <a class="nav-link" asp-controller="Medical" asp-action="Index">🩺 Medical</a>
                <a class="nav-link" asp-controller="Tools" asp-action="Index">Tools</a>
            </div>
        </div>
    </nav>
    <div class="container">
        @RenderBody()
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
