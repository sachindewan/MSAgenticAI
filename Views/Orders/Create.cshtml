@{
    ViewData["Title"] = "Create Order";
}

<div class="row justify-content-center">
    <div class="col-md-5">
        <h4 class="mb-3">➕ Create Order</h4>
        <div class="card p-4">
            <form asp-action="Create" method="post">
                <div class="mb-3">
                    <label class="form-label">User ID</label>
                    <input name="userId" class="form-control" placeholder="e.g. u1" required />
                </div>
                <div class="mb-3">
                    <label class="form-label">Items <small class="text-muted">(comma separated)</small></label>
                    <input name="items" class="form-control" placeholder="e.g. Laptop, Mouse" required />
                </div>
                <div class="mb-3">
                    <label class="form-label">Total ($)</label>
                    <input name="total" type="number" step="0.01" class="form-control" required />
                </div>
                <button type="submit" class="btn btn-primary w-100">Create</button>
                <a asp-action="Index" class="btn btn-outline-secondary w-100 mt-2">Cancel</a>
            </form>
        </div>
    </div>
</div>
